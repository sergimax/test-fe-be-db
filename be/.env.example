# =============================================================================
# Copy this file to .env and adjust if needed:
#   copy .env.example .env   (PowerShell / cmd on Windows)
#
# WHY: Real secrets/connection settings should not be committed to git.
#      .env.example is the safe template; .env is your local copy (gitignored).
# =============================================================================

# Host is "localhost" because Docker maps container port 5432 to your machine.
# If Node ran *inside* Docker on the same Compose network, host would be "db".
DATABASE_URL=postgresql://app:app@localhost:5432/appdb

# Same pieces as DATABASE_URL, useful if you prefer separate vars later.
PGHOST=localhost
PGPORT=5432
PGUSER=app
PGPASSWORD=app
PGDATABASE=appdb
